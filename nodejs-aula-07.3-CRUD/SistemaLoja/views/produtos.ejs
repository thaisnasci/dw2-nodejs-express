<%- include ('partials/header.ejs') %>
<%- include ('partials/navbar.ejs') %>
    <div class="container">
            <div class="card">
                <div class="card-header">
                    <h1>Cadastrar produtos</h1>
                </div>
                <div class="card-body">
                    <form action="/produtos/cadastrar" method="POST">
                        <label>Nome do produto:</label>
                        <input type="text" name="nome" placeholder="Insira o nome do Produto" class="form-control" required>
                        <label>Preço do produto:</label>
                        <input type="text" name="preco" placeholder="Insira o preço" class="form-control" required>
                        <label>Categoria do produto:</label>
                        <input type="text" name="categoria" placeholder="Insira a categoria" class="form-control" required>
                        <br>
                        <button type="submit" class="btn btn-success">Cadastrar</button>
                        <button type="reset" class="btn btn-danger">Limpar</button>
                    </form>
                    <hr>
                </div>
            </div>
    <div class="container">
        <div class="card">
            <div class="card-header">
                <h1>Produtos</h1>
            </div>
            <div class="card-body">
                <table>
                    <thead>
                        <tr>
                            <th></th>
                            <th>Nome:</th>
                            <th>Preço:</th>
                            <th>Categoria:</th>
                            <th colspan="2" style="align-items: center;">Excluir:</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% produtos.forEach(produto => { %>
                        <tr>
                            <td><img src="imgs/product.png" width="30px"></td>
                            <td><%= produto.nome %></td>
                            <td><%= produto.preco.toLocaleString('pt-br', {style: 'currency', currency: 'BRL'}) %></td>
                            <td><%= produto.categoria %></td>
                            <td>
                                <a href="/produtos/excluir/<%=produto.id%>">
                                <button class="btn btn-danger" onclick="return confirm('Tem certeza que deseja excluir o produto: <%=produto.nome %>')">Excluir</button>
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

<%- include ('partials/footer.ejs') %>
